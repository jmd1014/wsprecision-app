# Streamlit Cloud에 등록할 시크릿 (이 파일은 예시. 실제 secrets.toml은 절대 commit 금지)
# Streamlit Cloud 대시보드 > App settings > Secrets 에 동일 내용 붙여넣기

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
anon_key = "YOUR_ANON_KEY"
service_role_key = "YOUR_SERVICE_ROLE_KEY"

[google_drive]
# 백업용 서비스 어카운트 JSON (한 줄로 압축 또는 멀티라인)
service_account_json = """
{
  "type": "service_account",
  ...
}
"""
backup_folder_id = "GOOGLE_DRIVE_FOLDER_ID"

[gspread]
# 구글시트 sync용 (백업과 같은 서비스 어카운트 사용 가능)
service_account_json = "위 google_drive와 동일하게 사용"

[slack]
webhook_url = "https://hooks.slack.com/services/..."
default_channel = "#경영-소재관리"

[auth]
# 1차: 자체 인증 비밀번호 (bcrypt 해시), 향후 Google OAuth로 교체
admin_username = "admin"
admin_password_hash = "$2b$12$..."

[app]
company_name = "우성정밀"
company_address = "부산광역시 기장군 산단4로 71"
company_tel = "051-527-9963"
company_fax = "051-526-6024"
business_no = "606-02-14529"
ceo_name = "김태식"
default_payment = "말일 마감 60일 현금"
